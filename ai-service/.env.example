PORT=3001

# OpenRouter — use the same key style as Laravel (LLM_API_KEY) or OPENROUTER_API_KEY
LLM_API_KEY=
LLM_MODEL=google/gemini-2.0-flash-001
# API base (include /api). Use http://app:8000/api only when sync-graph runs inside Docker.
LARAVEL_API_URL=http://localhost:8000/api

# LangSmith tracing only — LangChain expects LANGCHAIN_API_KEY; we map LANGSMITH_API_KEY in envBootstrap.ts
LANGSMITH_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=alvorada-property-research

# Neo4j Graph RAG — leave empty to use SQL-only retrieval
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j-secret
